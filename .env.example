# ===========================================
# 易合同 - AI智能合同管理系统 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并根据实际环境填写
# cp .env.example .env.local
# ===========================================

# ---------- 基础配置 ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---------- Supabase 配置 ----------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---------- 数据库配置 ----------
# 开发：SQLite
DATABASE_URL="file:./prisma/dev.db"
# 生产：PostgreSQL
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ---------- 文件存储 ----------
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=contracts

# ---------- AI 解析服务 ----------
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key

# ===========================================
# 通知推送通道配置
# ===========================================

# ----- 通道1：站内信（默认开启，无需配置）-----
# 系统自动写入 reminders 表，用户在站内查看

# ----- 通道2：邮件通知（二选一）-----
# 方式A：Resend（推荐，每月免费100封）
# 注册：https://resend.com
# RESEND_API_KEY=re_xxx
# 方式B：SMTP（自建邮件服务器）
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_pass
# SMTP_SECURE=false
# SMTP_FROM=noreply@e-hetong.com

# ----- 通道3：微信订阅消息（推荐）-----
# 前提：已认证微信服务号
# 公众平台：功能 → 订阅通知 → 添加"合同到期提醒"模板
# WX_APPID=wx你的公众号AppID
# WX_SECRET=你的公众号AppSecret
# WX_SUBSCRIBE_TEMPLATE_ID=合同到期提醒的模板ID

# ----- 通道4：微信模板消息（旧，已逐步被订阅消息替代）-----
# WX_TEMPLATE_ID_REMINDER=你的模板ID

# ----- 通道5：短信通知（预留，需开通服务商）-----
# 服务商：阿里云/腾讯云/七牛云
# SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY=你的AccessKey
# SMS_SECRET_KEY=你的AccessSecret
# SMS_SIGN=易合同
# SMS_TEMPLATE_REMINDER=短信模板ID

# ----- 通道6：AI电话通知（预留，需开通服务商）-----
# 服务商：阿里云语音服务/腾讯云语音通知
# AI_CALL_PROVIDER=aliyun
# AI_CALL_APP_ID=xxx
# AI_CALL_API_KEY=xxx
# AI_CALL_TEMPLATE_ID=xxx
# AI_CALL_SHOW_NUMBER=4000000000
# AI_CALL_VOICE=woman

# ===========================================
# 微信支付配置
# ===========================================
WXPAY_APPID=your_wechat_appid
WXPAY_MCHID=your_merchant_id
WXPAY_API_KEY=your_api_v3_key
WXPAY_SERIAL_NO=your_cert_serial_no
WXPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WXPAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify

# ---------- 定时任务 ----------
CRON_SECRET=your-cron-secret-change-me

# ---------- 其他 ----------
NEXT_PUBLIC_SITE_NAME=易合同
